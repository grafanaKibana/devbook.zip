{% if not (contentClasses and "canvas-page" in contentClasses) %}
<footer class="dg-contact-footer">
  <nav class="dg-contact-footer-links" aria-label="Contact links">
    {% if meta.contact.email %}
      <a href="mailto:{{meta.contact.email}}" class="dg-contact-link">
        <i data-lucide="mail"></i>
        <span>{{meta.contact.email}}</span>
      </a>
    {% endif %}
    {% if meta.contact.linkedin %}
      <a href="{{meta.contact.linkedin}}" target="_blank" rel="noopener noreferrer" class="dg-contact-link">
        <svg class="svg-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.44-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.63-1.85 3.36-1.85 3.59 0 4.25 2.36 4.25 5.44v6.3h.03ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.8 0 0 .77 0 1.73v20.54C0 23.23.8 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z" />
        </svg>
        <span>{{meta.contact.name or "LinkedIn"}}</span>
      </a>
    {% endif %}
    {% if meta.contact.github %}
      <a href="{{meta.contact.github}}" target="_blank" rel="noopener noreferrer" class="dg-contact-link">
        <svg class="svg-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.92.58.1.79-.25.79-.56v-2.14c-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.17 1.18.92-.26 1.91-.38 2.89-.39.98.01 1.97.13 2.89.39 2.2-1.49 3.17-1.18 3.17-1.18.63 1.58.23 2.75.11 3.04.74.81 1.19 1.83 1.19 3.09 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.16c0 .31.21.67.79.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
        </svg>
        <span>GitHub</span>
      </a>
    {% endif %}
  </nav>
</footer>
{% endif %}
