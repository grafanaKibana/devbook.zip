{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/suggest-review.mjs\"",
            "statusMessage": "Tracking note review requirements..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/enforce-review.mjs\"",
            "statusMessage": "Checking note review receipts..."
          }
        ]
      }
    ]
  }
}
