{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Ingestion": {
    "ContentRootPath": "../../../Vault/Software Engineering",
    "MaxFilesPerRequest": 200,
    "MaxFileSizeBytes": 1048576
  },
  "Chunking": {
    "MaxChunkLength": 1200,
    "OverlapLength": 200,
    "DocumentBatchSize": 10
  },
  "Embeddings": {
    "ModelId": "text-embedding-3-small",
    "BatchSize": 16,
    "VectorDimensions": 384,
    "Endpoint": ""
  },
  "AllowedHosts": "*"
}
