{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devbook.local/schemas/golden-rag-cases-v2.schema.json",
  "title": "DevBook Golden RAG Dataset v2",
  "description": "Per-Mongo-collection RAG retrieval dataset with graded chunk-id expectations.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "collection", "cases"],
  "properties": {
    "version": {
      "const": 2,
      "description": "Dataset schema version."
    },
    "collection": {
      "type": "string",
      "pattern": "^chunks\\.(fixedsize|markdownsection|semantic)$",
      "description": "MongoDB chunk collection evaluated by this file. One v2 dataset file maps to one collection."
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "query", "difficulty", "expected"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable case identifier unique inside the collection dataset."
        },
        "query": {
          "type": "string",
          "minLength": 1,
          "description": "User-facing retrieval query submitted to /rag/search."
        },
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"],
          "description": "Expected retrieval difficulty for reporting and balanced dataset generation."
        },
        "expected": {
          "$ref": "#/$defs/gradedExpectations"
        }
      }
    },
    "gradedExpectations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryChunkIds", "supportingChunkIds", "acceptableChunkIds"],
      "properties": {
        "primaryChunkIds": {
          "$ref": "#/$defs/chunkIds",
          "minItems": 1,
          "description": "Chunks that directly answer the query. Retrieval should strongly prefer these near the top."
        },
        "supportingChunkIds": {
          "$ref": "#/$defs/chunkIds",
          "description": "Chunks that add useful context but are not the main answer evidence."
        },
        "acceptableChunkIds": {
          "$ref": "#/$defs/chunkIds",
          "description": "Related chunks that should not be treated as harmful false positives, but should receive little or no positive credit."
        }
      }
    },
    "chunkIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "examples": [
    {
      "version": 2,
      "collection": "chunks.markdownsection",
      "cases": [
        {
          "id": "markdownsection-rag-evaluation-001",
          "query": "Why should RAG evaluation separate retrieval quality from answer quality?",
          "difficulty": "medium",
          "expected": {
            "primaryChunkIds": ["chunk_rag_evaluation_md_0001"],
            "supportingChunkIds": ["chunk_rag_monitoring_md_0004"],
            "acceptableChunkIds": ["chunk_golden_test_set_md_0002"]
          }
        }
      ]
    }
  ]
}
