{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devbook.local/schemas/group-file.schema.json",
  "title": "DevBook Golden Dataset Group File",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "collection", "minimumCosineSimilarity", "minimumQueryReadyContent", "acceptedGroups", "rejectedGroups", "auditGroups"],
  "properties": {
    "version": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "collection": { "type": "string", "pattern": "^chunks\\.(fixedsize|markdownsection|semantic)$" },
    "minimumCosineSimilarity": { "type": "number" },
    "minimumQueryReadyContent": { "$ref": "#/$defs/minimumQueryReadyContent" },
    "acceptedGroups": { "type": "array", "items": { "$ref": "#/$defs/group" } },
    "rejectedGroups": { "type": "array", "items": { "$ref": "#/$defs/group" } },
    "auditGroups": { "type": "array", "items": { "$ref": "#/$defs/group" } }
  },
  "$defs": {
    "minimumQueryReadyContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minCharacters", "minUniqueTerms"],
      "properties": {
        "minCharacters": { "type": "integer" },
        "minUniqueTerms": { "type": "integer" }
      }
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "collection", "topic", "basis", "queryGenerationReady", "seedChunkId", "chunkIds", "documentIds", "sourceTitles", "headings", "topTerms", "validation", "chunks"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "collection": { "type": "string" },
        "topic": { "type": "string" },
        "basis": { "type": "string" },
        "queryGenerationReady": { "type": "boolean" },
        "seedChunkId": { "type": "string" },
        "chunkIds": { "type": "array", "items": { "type": "string" } },
        "documentIds": { "type": "array", "items": { "type": "string" } },
        "sourceTitles": { "type": "array", "items": { "type": "string" } },
        "headings": { "type": "array", "items": { "type": "string" } },
        "topTerms": { "type": "array", "items": { "type": "string" } },
        "validation": { "$ref": "#/$defs/validation" },
        "chunks": { "type": "array", "items": { "$ref": "#/$defs/chunkForPrompt" } }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepted", "sharedTerms", "rootCount", "headingCount", "documentCount", "averageSimilarity", "minimumSimilarity"],
      "properties": {
        "accepted": { "type": "boolean" },
        "sharedTerms": { "type": "array", "items": { "type": "string" } },
        "rootCount": { "type": "integer" },
        "headingCount": { "type": "integer" },
        "documentCount": { "type": "integer" },
        "averageSimilarity": { "type": "number" },
        "minimumSimilarity": { "type": "number" }
      }
    },
    "chunkForPrompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chunkId", "documentId", "chunkOrder", "citationLabel", "text"],
      "properties": {
        "chunkId": { "type": "string" },
        "documentId": { "type": "string" },
        "heading": { "type": ["string", "null"] },
        "chunkOrder": { "type": "integer" },
        "citationLabel": { "type": "string" },
        "similarityToSeed": { "type": ["number", "null"] },
        "text": { "type": "string" }
      }
    }
  }
}
