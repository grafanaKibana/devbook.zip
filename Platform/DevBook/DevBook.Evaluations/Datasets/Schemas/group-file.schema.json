{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devbook.local/schemas/group-file.schema.json",
  "title": "DevBook Golden Dataset Group File",
  "description": "Cross-note groups used for query generation. A group is a seed note plus the notes it links to via wikilinks, so generated queries can require evidence spanning multiple pages.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "groups"],
  "properties": {
    "version": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "groups": { "type": "array", "items": { "$ref": "#/$defs/group" } }
  },
  "$defs": {
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "seedTitle", "seedSourcePath", "noteCount", "sections"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "seedTitle": { "type": "string" },
        "seedSourcePath": { "type": "string" },
        "noteCount": {
          "type": "integer",
          "description": "Number of distinct source notes contributing sections to this group."
        },
        "sections": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/groupSection" } }
      }
    },
    "groupSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["localId", "title", "sourcePath", "charCount"],
      "properties": {
        "localId": {
          "type": "string",
          "description": "Stable per-group section id (S1, S2, ...) the LLM references when classifying evidence."
        },
        "title": { "type": "string" },
        "sourcePath": { "type": "string" },
        "heading": { "type": ["string", "null"] },
        "charCount": { "type": "integer" }
      }
    }
  }
}
