{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devbook.local/schemas/golden-rag-cases.schema.json",
  "title": "DevBook Hand-Curated Golden RAG Cases",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "cases"],
  "properties": {
    "version": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "query", "expectedSources"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 },
        "expectedSources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/expectedSource" }
        },
        "expectedAnswerSummary": { "type": "string" }
      }
    },
    "expectedSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "heading": { "type": ["string", "null"] },
        "snippet": { "type": ["string", "null"] }
      }
    }
  }
}
