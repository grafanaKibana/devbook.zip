{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devbook.local/schemas/generated-dataset.schema.json",
  "title": "DevBook Generated Golden RAG Dataset",
  "description": "Per-Mongo-collection RAG retrieval dataset with graded chunk expectations.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "collection", "cases"],
  "properties": {
    "version": {
      "const": 2,
      "description": "Dataset schema version."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when this dataset file was generated."
    },
    "collection": {
      "type": "string",
      "pattern": "^chunks\\.(fixedsize|markdownsection|semantic)$",
      "description": "MongoDB chunk collection evaluated by this file."
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "query", "difficulty", "expected"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "expected": { "$ref": "#/$defs/gradedExpectations" }
      }
    },
    "gradedExpectations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryChunks", "supportingChunks", "acceptableChunks"],
      "properties": {
        "primaryChunks": { "$ref": "#/$defs/chunks", "minItems": 1 },
        "supportingChunks": { "$ref": "#/$defs/chunks" },
        "acceptableChunks": { "$ref": "#/$defs/chunks" }
      }
    },
    "chunks": {
      "type": "array",
      "items": { "$ref": "#/$defs/chunk" }
    },
    "chunk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chunkId", "documentId", "chunkOrder", "citationLabel", "text"],
      "properties": {
        "chunkId": { "type": "string", "minLength": 1 },
        "documentId": { "type": "string", "minLength": 1 },
        "heading": { "type": ["string", "null"] },
        "chunkOrder": { "type": "integer" },
        "citationLabel": { "type": "string" },
        "text": { "type": "string", "minLength": 1 }
      }
    }
  }
}
