{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://localhost:5288",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "https://localhost:7280;http://localhost:5288",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "Run Dataset Generation": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "run Platform/DevBook/DevBook.Evaluations/RunDatasetGeneration.cs -- --max-groups 120",
      "workingDirectory": "../../.."
    },
    "Run Dataset Generation - Dry Run": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "run Platform/DevBook/DevBook.Evaluations/RunDatasetGeneration.cs -- --dry-run --max-groups 120",
      "workingDirectory": "../../.."
    },
    "Run Dataset Generation - Mini": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "run Platform/DevBook/DevBook.Evaluations/RunDatasetGeneration.cs -- --label mini --max-groups 10",
      "workingDirectory": "../../.."
    },
    "Run Dataset Generation - Mini - Dry Run": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "run Platform/DevBook/DevBook.Evaluations/RunDatasetGeneration.cs -- --label mini --dry-run --max-groups 10",
      "workingDirectory": "../../.."
    },
    "Run Evaluation": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "run Platform/DevBook/DevBook.Evaluations/RunEvaluation.cs -- --name RAG.Search",
      "workingDirectory": "../../.."
    },
    "Run Evaluation - Open Report": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "run Platform/DevBook/DevBook.Evaluations/RunEvaluation.cs -- --name RAG.Search --open-browser",
      "workingDirectory": "../../.."
    },
    "Run Report (Fancy)": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "run Platform/DevBook/DevBook.Evaluations/RunReport.cs -- --run latest",
      "workingDirectory": "../../.."
    },
    "Run Report (Fancy) - Open": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "run Platform/DevBook/DevBook.Evaluations/RunReport.cs -- --run latest --open-browser",
      "workingDirectory": "../../.."
    }
  }
}
