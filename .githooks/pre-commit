#!/usr/bin/env bash
set -e

# Pre-commit hook for DevBook Obsidian repo
# Runs vault maintenance automations on staged files

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Obsidian Git plugin can run hooks with a minimal PATH.
# Add common Node binary locations so markdownlint-cli2 is discoverable.
for bin_dir in /opt/homebrew/bin /opt/homebrew/opt/node@22/bin /usr/local/bin; do
    [[ -d "$bin_dir" ]] && PATH="$bin_dir:$PATH"
done

# Collect staged Markdown files under Vault/ only (skip .opencode/, root AGENTS.md, etc.)
STAGED_MD=()
while IFS= read -r file; do
    [[ "$file" =~ \.(md|MD)$ ]] || continue
    [[ "$file" == Vault/* ]] || continue
    STAGED_MD+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR)

# If no staged Markdown files, skip automations
if [[ ${#STAGED_MD[@]} -eq 0 ]]; then
    exit 0
fi

# Run vault maintenance automations in order
echo "[pre-commit] Running vault automations..."

# 1. Sync folder frontmatter (derives status/priority/level from children)
ROLLUP_CHANGED=$(python3 "$REPO_ROOT/.scripts/sync-folder-rollup-frontmatter.py" --write --force --print-changed)
if [[ -n "$ROLLUP_CHANGED" ]]; then
    while IFS= read -r file; do
        git add "$REPO_ROOT/$file"
    done <<< "$ROLLUP_CHANGED"
    echo "[pre-commit] ✓ Folder frontmatter synced ($(echo "$ROLLUP_CHANGED" | wc -l | tr -d ' ') notes)"
fi

# 2. Generate roadmap canvas from folder structure
python3 "$REPO_ROOT/.scripts/generate-roadmap.py"
ROADMAP_FILE="Vault/Software Engineering/Roadmap.canvas"
if ! git diff --quiet -- "$REPO_ROOT/$ROADMAP_FILE" 2>/dev/null; then
    git add "$REPO_ROOT/$ROADMAP_FILE"
    echo "[pre-commit] ✓ Roadmap canvas regenerated"
fi

### MD040 LINT — markdownlint-cli2 (staged-only) ###
if [[ ${#STAGED_MD[@]} -gt 0 ]]; then
    echo "[pre-commit] Checking fenced code block languages (MD040)..."

    # markdownlint-cli2 and its config live in the Quartz web project (Web/).
    LINT_BIN="$REPO_ROOT/Web/node_modules/.bin/markdownlint-cli2"
    LINT_CONFIG="$REPO_ROOT/Web/.markdownlint.json"

    # Run only on staged files; pass each file as a positional argument
    LINT_CMD=()
    if [[ -x "$LINT_BIN" ]]; then
        LINT_CMD=("$LINT_BIN")
    elif command -v npx >/dev/null 2>&1; then
        LINT_CMD=(npx --no-install markdownlint-cli2)
    else
        echo ""
        echo "[pre-commit] ✗ markdownlint-cli2 runtime not found."
        echo "  Install dependencies: (cd Web && npm install)"
        echo "  Or ensure Node tools are on PATH for GUI apps (Obsidian)."
        exit 1
    fi

    if [[ ! -f "$LINT_CONFIG" ]]; then
        echo ""
        echo "[pre-commit] ✗ .markdownlint.json not found at Web/.markdownlint.json."
        exit 1
    fi

    if ! "${LINT_CMD[@]}" --config "$LINT_CONFIG" "${STAGED_MD[@]}"; then
        echo ""
        echo "[pre-commit] ✗ MD040: Add a language to every fenced code block."
        echo "  Fallback: use 'text' when no specific language applies."
        echo "  Fix all violations above, then re-stage and commit."
        exit 1
    fi
    echo "[pre-commit] ✓ Fenced code blocks OK"
fi

exit 0
