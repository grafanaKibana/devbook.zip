{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "isolatedModules": true,
    "noEmit": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strict": false
  },
  "include": ["src/**/*.ts", "src/**/*.cts"],
  "exclude": ["generated/**"]
}
