<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

{% if metatags %}
    {% for name, content in metatags %}
        {% if name.includes("og:") %}
          <meta property="{{ name }}" content="{{ content }}">
        {% else %}
          <meta name="{{ name }}" content="{{ content }}">
        {% endif %}
    {% endfor %}
{% endif %}

<script type="importmap">
{
  "imports": {
    "d3-force": "https://cdn.jsdelivr.net/npm/d3-force@3.0.0/+esm",
    "d3-selection": "https://cdn.jsdelivr.net/npm/d3-selection@3.0.0/+esm",
    "d3-zoom": "https://cdn.jsdelivr.net/npm/d3-zoom@3.0.0/+esm",
    "d3-drag": "https://cdn.jsdelivr.net/npm/d3-drag@3.0.0/+esm"
  }
}
</script>
<script src="https://cdn.jsdelivr.net/npm/pixi.js@7.4.2/dist/pixi.min.js"></script>

<script async type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
    mermaid.initialize({ startOnLoad: true });
</script>
<script async src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.25.0/prism.min.js" integrity="sha512-hpZ5pDCF2bRCweL5WoA0/N1elet1KYL5mx3LP555Eg/0ZguaHawxNvEjF6O3rufAChs16HVNhEc6blF/rZoowQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script async src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.25.0/plugins/autoloader/prism-autoloader.min.js" integrity="sha512-sv0slik/5O0JIPdLBCR2A3XDg/1U3WuDEheZfI/DI5n8Yqc3h5kjrnr46FGBNiUAJF7rE4LHKwQ/SoSLRKAxEA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

{%include "components/calloutScript.njk"%}

<script defer src="https://fastly.jsdelivr.net/npm/@alpinejs/persist@3.11.1/dist/cdn.min.js"></script>
<script defer src="https://fastly.jsdelivr.net/npm/alpinejs@3.11.1/dist/cdn.min.js"></script>

<script src="https://fastly.jsdelivr.net/npm/whatwg-fetch@3.6.2/dist/fetch.umd.min.js" crossorigin="anonymous" referrerpolicy="no-referrer" async></script>

{%-if meta.themeStyle%}
    <link href="/styles/obsidian-base.css" rel="stylesheet">
    <link href="{{meta.themeStyle}}" rel="stylesheet">
{% else %}
    <link href="/styles/style.css" rel="stylesheet">
{%endif%}
<link href="/styles/digital-garden-base.css" rel="stylesheet">

<link href="/styles/custom-style.css" rel="stylesheet">
{%- for style in dynamics.styles -%}
<link href="{{style}}?v={{meta.buildDate|isoDate}}" rel="stylesheet">
{%- endfor -%}

<!-- Prism syntax highlighting: classic Visual Studio (light) / VS Code Dark+ (dark). -->
<!-- Ready-made prism-themes, gated on prefers-color-scheme to match the site's theme script. -->
<!-- Loaded last so they win over the digital-garden's built-in code palette (obsidian-base / theme). -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism-themes/1.9.0/prism-vs.min.css" media="(prefers-color-scheme: light)" crossorigin="anonymous" referrerpolicy="no-referrer"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism-themes/1.9.0/prism-vsc-dark-plus.min.css" media="(prefers-color-scheme: dark)" crossorigin="anonymous" referrerpolicy="no-referrer"/>

{% favicons './.cache/favicon.normalized.svg', appleIconBgColor='#123' %}

{% if meta.styleSettingsCss %}
    <style>
        {{ meta.styleSettingsCss | safe }}
    </style>
{% endif %}
<style>
</style>
